modules = ["nodejs-20", "bash", "web", "java-graalvm22.3", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["github:1.0.0", "javascript_openai_ai_integrations:2.0.0"]
stack = "FULLSTACK_JS"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8181
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
SESSION_ENCRYPTION_KEY = "cd34649e77e70a4e9fd26543a2f8ae6c141327598481f7b0217016f7d2af6c13"

[userenv.development]
